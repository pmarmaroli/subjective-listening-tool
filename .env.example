# Azure Storage Configuration
# Get this from Azure Portal > Storage Account > Access keys > Connection string
AZURE_STORAGE_CONNECTION_STRING=your_storage_connection_string_here

# Web Page Access Password
# This password is used to authenticate users and manage projects
WEB_PAGE_PASSWORD=your_secure_password_here

# Server Port (optional, defaults to 3000 locally, Azure sets this automatically)
PORT=3000
